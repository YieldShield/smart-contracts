# Template for foundry environment variables.

# For local development, copy this file, rename it to .env, and fill in the values.

# We provide default values so developers can start prototyping out of the box,
# but we recommend getting your own API Keys for Production Apps.

# DEPLOYER_PRIVATE_KEY is used while deploying contract.
# On anvil chain the value of it can be empty since we use the prefunded account
# which comes with anvil chain to deploy contract.
# NOTE: You don't need to manually change the value of DEPLOYER_PRIVATE_KEY, it should
# be auto filled when run `yarn generate`.

# Alchemy rpc URL is used while deploying the contracts to some testnets/mainnets, checkout `foundry.toml` for it's use.
ALCHEMY_API_KEY=your-alchemy-api-key
# Etherscan API key is used to verify the contract on etherscan.
ETHERSCAN_API_KEY=your-etherscan-api-key
# Pyth Hermes authentication is required for every updater by July 31, 2026.
# The updater selects the legacy or upgraded official endpoint from the Pyth
# contract configured in the deployed PythOracle. Set PYTH_HERMES_URL only for
# an explicitly compatible provider or a deliberate cutover override.
PYTH_API_KEY=your-pyth-api-key
# PYTH_HERMES_URL=https://pyth.dourolabs.app/hermes
# Robinhood testnet should use a provider RPC for deployments and indexing.
# The public endpoint is rate-limited; use Alchemy or another production provider here.
ROBINHOOD_TESTNET_RPC_URL=https://robinhood-testnet.g.alchemy.com/v2/your-alchemy-api-key
# Optional deploy helper defaults. Set this to make
# `yarn deploy --network robinhoodTestnet` use the funded test keystore without a prompt.
# ROBINHOOD_TESTNET_KEYSTORE_ACCOUNT=test
# ETH_KEYSTORE_ACCOUNT=test

# Robinhood testnet defaults to relaxed deploy guardrails so a funded test account
# can deploy without precomputed production Safe/codehash confirmations. Set true
# when rehearsing the stricter production checks on chain 46630.
# YS_ROBINHOOD_TESTNET_STRICT_PRODUCTION_GUARDS=false

# Production deploy script guardrails. Compute and review these before deploying:
# cast codehash <address> --rpc-url <rpc-url> after a dry run / reviewed deployment artifact.
# YS_PRODUCTION_FACTORY_IMPLEMENTATION_CODEHASH=
# YS_PRODUCTION_POOL_IMPLEMENTATION_CODEHASH=
# YS_PRODUCTION_PYTH_ORACLE_CODEHASH=
# YS_PRODUCTION_CHAINLINK_ORACLE_CODEHASH=

# Robinhood Chain deployments use Chainlink feeds. Set the relevant sequencer
# uptime feed from Chainlink docs, or explicitly opt out only for testnet dry runs.
# YS_ROBINHOOD_TESTNET_SEQUENCER_FEED=
YS_ROBINHOOD_ALLOW_MISSING_SEQUENCER_FEED=false
# Set true for a product-loop Robinhood testnet rehearsal with demo assets, feeds, pools, and seed liquidity.
# YS_ROBINHOOD_TESTNET_SEED_DEMO_ASSETS=true
# Default account for localhost / use "scaffold-eth-custom" if you wish to use a generated account or imported account
LOCALHOST_KEYSTORE_ACCOUNT=scaffold-eth-default
