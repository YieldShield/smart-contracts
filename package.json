{
  "name": "@yieldshield/smart-contracts",
  "version": "0.0.1",
  "description": "Foundry workspace for YieldShield protocol smart contracts.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YieldShield/smart-contracts.git"
  },
  "bugs": {
    "url": "https://github.com/YieldShield/smart-contracts/issues"
  },
  "homepage": "https://github.com/YieldShield/smart-contracts#readme",
  "engines": {
    "node": ">=22.14.0 <25"
  },
  "scripts": {
    "account": "make account",
    "account:generate": "node scripts-js/generateKeystore.js",
    "account:import": "node scripts-js/importAccount.js",
    "chain": "make chain",
    "build": "forge build --offline",
    "clean": "forge clean",
    "compile": "make compile",
    "check:foundry-lock": "node scripts-js/check-foundry-lock.cjs",
    "coverage-check": "node scripts-js/checkCoverage.js lcov.info",
    "deploy": "node scripts-js/parseArgs.js",
    "flatten": "make flatten",
    "finalize:deployment-manifest": "node scripts-js/finalizeDeploymentManifest.js",
    "fork": "make fork FORK_URL=${1:-mainnet}",
    "format": "make format",
    "postinstall": "shx cp -n .env.example .env",
    "lint": "make lint",
    "robinhood:mock-feeds": "node scripts-js/robinhood-mock-feed-operator.cjs",
    "security": "make security",
    "size-check:robinhood-deployment": "node scripts-js/checkDeploymentTargetSizes.js",
    "size-check": "node scripts-js/checkContractSizes.js",
    "test": "forge test --offline",
    "test:fork": "FORK_TESTS_ENABLED=true FORK_TESTS_REQUIRED=true forge test --match-path 'test/*Fork.t.sol'",
    "test:scripts": "node --test scripts-js/__tests__/*.test.cjs",
    "verify": "make verify RPC_URL=${1:-localhost}"
  },
  "dependencies": {
    "@pythnetwork/hermes-client": "^3.1.0",
    "@pythnetwork/pyth-sdk-solidity": "4.3.1",
    "dotenv": "~17.4.2",
    "ethers": "^6.17.0",
    "prettier": "~3.9.6",
    "qrcode": "~1.5.3",
    "toml": "~4.1.2"
  },
  "devDependencies": {
    "shx": "^0.4.0"
  }
}
