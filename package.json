{
  "name": "@yieldshield/smart-contracts",
  "version": "0.0.1",
  "description": "Foundry workspace for YieldShield protocol smart contracts.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YieldShield/smart-contracts.git"
  },
  "bugs": {
    "url": "https://github.com/YieldShield/smart-contracts/issues"
  },
  "homepage": "https://github.com/YieldShield/smart-contracts#readme",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "account": "make account",
    "account:generate": "node scripts-js/generateKeystore.js",
    "account:import": "node scripts-js/importAccount.js",
    "account:reveal-pk": "node scripts-js/revealPK.js",
    "chain": "make chain",
    "build": "forge build --offline",
    "clean": "forge clean",
    "compile": "make compile",
    "deploy": "node scripts-js/parseArgs.js",
    "flatten": "make flatten",
    "fork": "make fork FORK_URL=${1:-mainnet}",
    "format": "make format",
    "postinstall": "shx cp -n .env.example .env",
    "lint": "make lint",
    "security": "make security",
    "size-check": "node scripts-js/checkContractSizes.js",
    "test": "forge test --offline",
    "verify": "make verify RPC_URL=${1:-localhost}"
  },
  "dependencies": {
    "@pythnetwork/pyth-evm-js": "^2.0.0",
    "axios": "^1.15.0",
    "dotenv": "~17.4.2",
    "envfile": "~6.18.0",
    "ethers": "^6.16.0",
    "prettier": "~3.8.3",
    "qrcode": "~1.5.3",
    "toml": "~3.0.0"
  },
  "devDependencies": {
    "shx": "^0.4.0"
  }
}
